Acmm_t acmm(&moisture);

#define TIMER_DIVIDER         16  //  Hardware timer clock divider
#define TIMER_MSEC_2_TICK(sec)       ((TIMER_BASE_CLK / TIMER_DIVIDER) >> 10)

/* default initializtion via BSS */
int acmmAggOver = ACMM_AGGOVER;
int acmmFreq = ACMM_FREQ;

#ifdef USE_ARIMA
  static ARIMAModel arimaMod;
  static std::vector<double> obs;
  Predictions preds;
#endif

//xQueueHandle timer_queue;

/*
 * @note If the intr_alloc_flags value ESP_INTR_FLAG_IRAM is set,
 *       the handler function must be declared with IRAM_ATTR attribute
 *       and can only call functions in IRAM or ROM. It cannot call other timer APIs.
 *       Use direct register access to configure timers from inside the ISR in this case.
 *
 *       But here, it is quite a long code, so make it not in IRAM
 *
 *       Finally, timer code is IRAM compatible, GPIO not and ARIMA not.
 *       void IRAM_ATTR timer_isr(void *para)
 *
 * */
void timer_isr(void *para)
{
	timg_dev_t* timerGrpPtr;
	switch (ACMM_TIMER_GRP){
	case TIMER_GROUP_0:
		timerGrpPtr = &TIMERG0;
		break;
	case TIMER_GROUP_1:
		timerGrpPtr = &TIMERG1;
		break;
	}

	/* get the interrupt status */
	uint32_t intr_status = timerGrpPtr->int_st_timers.val;
	/* check that this is our timer who fired this*/
	if (!(intr_status & BIT(ACMM_TIMER_IDX)))
		return;

	timerGrpPtr->int_clr_timers.val |= BIT(ACMM_TIMER_IDX);	//clear the timer interrupt

	if (acmm.getOpMode() == acmmOpMode_t::sleep){ //we were sleeping, time to run
		acmm.setOpMode(acmmOpMode_t::run);
		// we had (in sleep) both outputs set to HiZ,
		//to prevent any pattern, set outputs to random state
		acmm.setHRandom();
		//and skip any sampling this time, to allow proper capa saturation
		return;
	}

    static int iterInner=0, iterAgg=0;
    static int acmmInnerMin=INT16_MAX, acmmInnerMax = 0, acmmClean = 0, acmmMin = INT16_MAX;
    static int acmmMinPrev;
    int raw;

    if (acmm.takeSampleOnH1 == (acmm.state==acmmHbridgeState_t::H1pup)){
    	raw = analogRead(ACMM_INPIN);
    	acmm.switchH();
    }else{
    	acmm.switchH();
    	return;
    }
  
    acmmClean += raw; 
    if (acmmInnerMin>raw){
      acmmInnerMin = raw;
    } else if(acmmInnerMax<raw){
      acmmInnerMax = raw;
    }
  
  
    if (++iterInner == ACMM_SMALL_ITER){
      acmmClean -= acmmInnerMin;
      acmmClean -= acmmInnerMax;
      acmmClean = acmmClean / (ACMM_SMALL_ITER - 2);

      iterInner = 0; acmmInnerMax = 0; acmmInnerMin = INT16_MAX;
      
      if (iterAgg==0){
        acmmMin = INT16_MAX; 
      }
      if (acmmMin > acmmClean){
        acmmMin = acmmClean;
      }
      if (++iterAgg == acmmAggOver){
        /*do some lp bessel filtering on acmmMin, 
        * don't publish - better do it in slower regime or not at all, just leave it for measurement messages
        */

    	*acmm.pMoisture = (ACMM_A1 * acmmMin + ACMM_A2 * acmmMinPrev + ACMM_B1 * *acmm.pMoisture) / (ACMM_A1 + ACMM_A2 + ACMM_B1);
        /* new smooth value is calculated, may rest for some time*/
        #ifdef USE_ARIMA
          if (obs.size() < arimaMod.ar_params.size())
            obs.push_back(acmmMin);
          else{
            std::rotate(obs.begin(),obs.begin()+1,obs.end());
            obs.back() = acmmMin;
            preds = ARIMAForecaster::forecast(arimaMod, 1, obs);
            ESP_LOGI(TAG, "ARIMA: %f\n",preds.values[0]);
          }
        #endif
        acmmMinPrev = acmmMin;

        iterAgg = 0;
        acmm.setOpMode(acmmOpMode_t::sleep);
      }
    }

	timerGrpPtr->hw_timer[ACMM_TIMER_IDX].update = 1;		//re-enable update
	timerGrpPtr->hw_timer[ACMM_TIMER_IDX].alarm_high = (uint32_t) (acmm.timerPeriod>> 32);
	timerGrpPtr->hw_timer[ACMM_TIMER_IDX].alarm_low = (uint32_t) (acmm.timerPeriod);
	/* After the alarm has been triggered we need enable it again, so it is triggered the next time */
	timerGrpPtr->hw_timer[ACMM_TIMER_IDX].config.alarm_en = TIMER_ALARM_EN;
    //xQueueSendFromISR(timer_queue, &evt, NULL);
}

