/**
 * @brief Configure ACMM H-bridge driving and adc input pins
 * @param  none
 * @return none
 */
bool Acmm_t::initH(void){
    gpio_config_t io_conf;
    //disable interrupt
    io_conf.intr_type = GPIO_INTR_DISABLE;
    //set as output Open Drain mode
    io_conf.mode = GPIO_MODE_OUTPUT_OD;
    //bit mask of the pins that you want to set
    io_conf.pin_bit_mask =  ((1ULL<<ACMM_H_PIN_1) | (1ULL<<ACMM_H_PIN_2));
    //disable pull-down mode
    io_conf.pull_down_en = GPIO_PULLDOWN_DISABLE;
    //disable pull-up mode
    io_conf.pull_up_en = GPIO_PULLUP_DISABLE;
    //configure GPIO with the given settings
    if (ESP_OK != gpio_config(&io_conf)){
    	return false;}

    io_conf.intr_type = GPIO_INTR_DISABLE;
    io_conf.pin_bit_mask = (1ULL << ACMM_INPIN);
    io_conf.mode = GPIO_MODE_INPUT;
    io_conf.pull_down_en = GPIO_PULLDOWN_DISABLE;
    io_conf.pull_up_en = GPIO_PULLUP_DISABLE;
    if (ESP_OK != gpio_config(&io_conf)){
    	return false;}

    logit(LOGLVL_SETUP, "Acmm::init: done.\n");

    setH(acmmHbridgeState_t::Hiz);
  
}

/**
 * @brief Constructs ACMM object, not touching hardware resources. Please initialize hardware with init().
 * @param  apMoisture - a pointer to where moisture data should be stored
 * @return none
 */
Acmm_t::Acmm_t(float* apMoisture, acmmOpMode_t aOpMode){
	assert(apMoisture != nullptr);
	pMoisture = apMoisture;
	opMode = aOpMode;

#ifdef USE_ARIMA
	arimaMod.ar_params = ACMM_ARIMA_AR;
	arimaMod.d = ACMM_ARIMA_I;
	arimaMod.ma_params = ACMM_ARIMA_MA;
#endif

}

/**
 * @brief Constructs ACMM completely, ready to run, but still stopped.
 * @param  apMoisture - a pointer to where moisture data should be stored
 * @return none
 */
bool Acmm_t::init(void){
	assert(this->isHbridgeInit = this->initH()); 				// @suppress("Assignment in condition")
	assert(this->isAdcInit = this->initAdc()); 					// @suppress("Assignment in condition")
	assert(this->isTimerInit = this->initTimer(timerPeriod));	// @suppress("Assignment in condition")
}

/**
 * @brief Runs ACMM by starting the timer.
 * @param
 * @return true on ok
 */
bool Acmm_t::run(){
	this->isHbridgeInit || this->initH();
	this->isAdcInit || this->initAdc();
	this->isTimerInit || this->initTimer(timerPeriod);

	return (ESP_OK != timer_start(ACMM_TIMER_GRP, ACMM_TIMER_IDX));
}

/**
 * @brief Pauses ACMM by pausing the timer and setting Hbridge to HiZ.
 * @param
 * @return true on ok
 */
bool Acmm_t::stop(){
	int retval = timer_pause(ACMM_TIMER_GRP, ACMM_TIMER_IDX);
	setH(acmmHbridgeState_t::Hiz);
	return (ESP_OK != retval );
}

/**
 * @brief Selects between ACMM run and sleep mode. Does not start ACMM.
 * @param
 * @return true on ok
 */
void Acmm_t::setOpMode(acmmOpMode_t aMode){
	opMode = aMode;
	if (aMode == acmmOpMode_t::run){
		timerPeriod = TIMER_MSEC_2_TICK(ACMM_FREQ_2_MS(acmmFreq));
	}else{
		timerPeriod = TIMER_MSEC_2_TICK(ACMM_SLEEP);
        setH(acmmHbridgeState_t::Hiz);
	}
}

acmmOpMode_t Acmm_t::getOpMode(void) {
	return opMode;
}

/**
 * @brief Sets Hbridge to a state.
 * @param
 * @return none
 */
void Acmm_t::setH(acmmHbridgeState_t aState){
  switch (aState)
  {
  case acmmHbridgeState_t::H1pup:    
    gpio_set_level(ACMM_H_PIN_1, 1);
    gpio_set_level(ACMM_H_PIN_2, 0);
    break;
  case acmmHbridgeState_t::H2pup:
    gpio_set_level(ACMM_H_PIN_1, 0);
    gpio_set_level(ACMM_H_PIN_2, 1);
    break;
  case acmmHbridgeState_t::Hiz:
    gpio_set_level(ACMM_H_PIN_1, 1);
    gpio_set_level(ACMM_H_PIN_2, 1);
    break;
  default:
    initH();
    break;
  } 
  state = aState;
}


/**
 * @brief Sets ACMM Hbridge to a random polarity.
 * @param
 * @return none
 */
void Acmm_t::setHRandom(void){
    setH(static_cast<acmmHbridgeState_t>((esp_random() & 0x01) + 1));
}


/**
 * @brief Switches ACMM Hbridge polarity. If Hbridge polarity was HiZ, then random.
 * @param
 * @return none
 */
acmmHbridgeState_t Acmm_t::switchH(void){
  /*
  bit-wise arithmetic does not work on enum class (works on traditional enums)
  if (state != acmmHbridgeState_t::Hiz)
    set((acmmHbridgeState_t)((state ^ 0x03) & 0x03 ));
  else
    setRandomLR();
  */
  switch (state)
  {
  case acmmHbridgeState_t::H1pup:    
    setH(acmmHbridgeState_t::H2pup);
    break;
  case acmmHbridgeState_t::H2pup:
    setH(acmmHbridgeState_t::H1pup);
    break;
  default:
    setHRandom();
  }
  return state;    
}

/**
 * @brief delay implementation via NOP, kept in IRAM.
 * @param
 * @return none
 */
static void IRAM_ATTR delayUsbyNops(uint32_t us)
{
    uint32_t m = micros();
    if(us){
        uint32_t e = (m + us);
        if(m > e){ //overflow
            while(micros() > e){
                NOP();
            }
        }
        while(micros() < e){
            NOP();
        }
    }
}

/**
 * @brief Checks ACMM wiring, decide on which half-wave to sample
 * @param
 * @return true on ok
 */
bool Acmm_t::checkWires(void) {
  const byte rounds = 5;
  const int delayUs = 20000;
  int rawH1pup=0, rawH2pup=0;

  this->isHbridgeInit || this->initH();
  this->isAdcInit || this->initAdc();

  int val = adc1_get_raw(ACMM_INPIN);

  for (byte i=0; i<rounds; i++){
    //ESP_LOGI(TAG, "checkWires: adc = %d\n",analogRead(ACMM_INPIN));
    setH(acmmHbridgeState_t::H1pup);
    //ESP_LOGI(TAG, "checkWires: H1up...");
    delayUsbyNops(delayUs);
    //ESP_LOGI(TAG, " ... ");
    rawH1pup += adc1_get_raw(ACMM_INPIN);
    //ESP_LOGI(TAG, " read: %d.\n", rawH1pup);

    setH(acmmHbridgeState_t::H2pup);
    //ESP_LOGI(TAG, "checkWires: H2up...");
    delayUsbyNops(delayUs);
    //ESP_LOGI(TAG, " ... ");
    rawH2pup += adc1_get_raw(ACMM_INPIN);
    //ESP_LOGI(TAG, " read: %d.\n", rawH2pup);
  }
  ESP_LOGI(TAG, "checkWires: rawH1pup=%d, rawH2pup=%d.\n", rawH1pup/rounds, rawH2pup/rounds );

  if (abs(rawH1pup - rawH2pup) < ACMM_ADC_SHORTCUT_TOL * rounds){
    ESP_LOGI(TAG,"checkWires: ############################################\n");
    ESP_LOGI(TAG,"checkWires: Wrong connection of short-circuit on electrodes !!!!!! \n");
    ESP_LOGI(TAG,"checkWires: I did not detect much difference on ADC after switching the H-bridge polarity.\n");
    ESP_LOGI(TAG,"checkWires: Exchange electrodes' driving lines or remove short-circuit, or I don't know what...\n");
    ESP_LOGI(TAG,"checkWires: then stop and restart measurement.\n");
    ESP_LOGI(TAG,"checkWires: Will continue as standalone ADC input pin.\n");
    ESP_LOGI(TAG,"checkWires: ############################################\n");
  }
  takeSampleOnH1 = rawH1pup > rawH2pup;
  ESP_LOGI(TAG, "Chose to sample on %s.\n", (takeSampleOnH1) ? "H1up" : "H2up" );
  
  return true;
}
  

/**
 * @brief Initializes ADC1 used for ACMM: attenuation and bit-width.
 * @param
 * @return true on ok
 */
bool Acmm_t::initAdc(void) {
	if (ESP_OK != adc1_config_width(ACMM_BITS))
		return false;
	if (ESP_OK != adc1_config_channel_atten(ACMM_INPIN, ADC_ATTEN_DB_0))
		return false;
	return true;
}

/**
 * @brief Checks how fast ACMM can go, not to see input channel saturation effects.
 * @param
 * @return minimal half-period in ms
 */
uint16_t Acmm_t::speedCheck(){

  uint16_t raw;
  uint16_t raw1 = 0;
  uint32_t hwms = 1 << 9;
  uint32_t hwmsMin = 0;

  this->isAdcInit || this->initAdc();
  this->isHbridgeInit || this->initH();

  setHRandom();

  while (true)
  {
    raw = 0;
    for (int smallIter=0; smallIter < 32; smallIter++){
      if (takeSampleOnH1 == (state==acmmHbridgeState_t::H1pup)){
        raw += adc1_get_raw(ACMM_INPIN);
        switchH();
      }else{
        switchH();
      }
      delayUsbyNops(hwms << 10);
    }
    raw = raw >> 4;
    ESP_LOGI(TAG,"acmmSpeedCheck: hw=%4d sample=%5d", hwms, raw);
    if (raw >= ACMM_SPEED_CHECK_DROP * raw1){
      hwmsMin = hwms;
      ESP_LOGI(TAG," > %1.2f, OK.\n", ACMM_SPEED_CHECK_DROP);
    } else
      ESP_LOGI(TAG," < %1.2f, too fast.\n", ACMM_SPEED_CHECK_DROP);

    raw1 = raw;
    hwms = hwms >> 1;

    if (hwms==0)
      break;
  }
  return hwmsMin;

}





